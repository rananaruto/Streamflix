<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#FFFFFF20">
    <item>
        <layer-list>
            <!-- Base glass background -->
            <item>
                <shape android:shape="rectangle">
                    <gradient
                        android:type="linear"
                        android:angle="135"
                        android:startColor="#FFFFFF20"
                        android:endColor="#FFFFFF10" />
                    <corners android:radius="12dp" />
                </shape>
            </item>
            
            <!-- Border -->
            <item>
                <shape android:shape="rectangle">
                    <stroke
                        android:width="1dp"
                        android:color="#FFFFFF25" />
                    <corners android:radius="12dp" />
                </shape>
            </item>
        </layer-list>
    </item>
</ripple>
