<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:text="@string/extension_github"
        android:textAppearance="@style/TextAppearance.StreamFlix.Title"
        android:textColor="@color/text_primary" />

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.StreamFlix.TextInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/extension_url_hint">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_extension_url"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textUri"
            android:textColor="@color/text_primary" />
    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Enter the GitHub repository URL for the extension"
        android:textAppearance="@style/TextAppearance.StreamFlix.Caption"
        android:textColor="@color/text_secondary" />

</LinearLayout>
